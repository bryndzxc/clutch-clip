APP_NAME=ClutchClip
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Session ──────────────────────────────────────────────────────────────────
# local:      SESSION_DRIVER=database
# production: SESSION_DRIVER=redis  (reduces one DB write per authenticated request)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting / Filesystem ────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Queue ────────────────────────────────────────────────────────────────────
# local:      QUEUE_CONNECTION=database  (no Redis required)
# production: QUEUE_CONNECTION=redis
QUEUE_CONNECTION=database

# ─── Cache ────────────────────────────────────────────────────────────────────
# local:      CACHE_STORE=database  (no Redis required)
# production: CACHE_STORE=redis
CACHE_STORE=database
# CACHE_PREFIX=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Use phpredis (PHP extension) in production for best performance.
# Alternatively, use 'predis' if the extension is unavailable.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# REDIS_USERNAME=
# Set to empty string if Redis has no password (do NOT use the literal string "null"):
REDIS_PASSWORD=
REDIS_PORT=6379

# Logical database numbers — keep these on separate DBs so a FLUSHDB on one
# never affects another.  All three share the same Redis server/port above.
REDIS_DB=0           # default / general purpose
REDIS_CACHE_DB=1     # Laravel cache (CACHE_STORE=redis)
REDIS_QUEUE_DB=2     # Laravel queue (QUEUE_CONNECTION=redis)

# Override which named connection the queue driver uses.
# Must match a key under database.redis in config/database.php.
# REDIS_QUEUE_CONNECTION=queue

# retry_after must exceed the longest job $timeout in the codebase.
# CutClipsJob has a 1800s timeout — 1980 gives a 10% safety buffer.
# DB_QUEUE_RETRY_AFTER=1980
# REDIS_QUEUE_RETRY_AFTER=1980

# ── Redis queue worker stability (production) ─────────────────────────────────
# REDIS_QUEUE_BLOCK_FOR=5     # seconds per BLPOP cycle; never use 0 in prod —
#                             # 0 = indefinite block, idle TCP gets killed by
#                             # firewalls/NAT → "read error on connection"
# REDIS_QUEUE_TIMEOUT=5       # connection-establishment timeout (seconds)
# REDIS_QUEUE_READ_TIMEOUT=-1 # PHP-level read timeout; -1 = no limit (safe
#                             # because BLOCK_FOR already bounds BLPOP duration)

# ─── Python binary ────────────────────────────────────────────────────────────
PYTHON_BIN=/var/www/clutch-clip/python/.venv/bin/python

# ─── Highlight diagnostics (per-clip analysis to worker logs) ─────────────────
# Set to true to append --diagnose to the Python command. Output goes to stderr
# only — JSON contract unchanged. Disable in production after investigation.
HIGHLIGHT_DIAGNOSE=false

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (optional, for S3 storage) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── ClutchClip — upload limits ───────────────────────────────────────────────
CLUTCHCLIP_MAX_SIZE_MB=1536
CLUTCHCLIP_MAX_DURATION_MINUTES=60

# ─── ClutchClip — cleanup thresholds (hours) ─────────────────────────────────
CLUTCHCLIP_FAILED_RETENTION_HOURS=24
CLUTCHCLIP_ABANDONED_RETENTION_HOURS=12
# How long before a video stuck in a processing stage is auto-failed:
CLUTCHCLIP_STUCK_PROCESSING_HOURS=4
# Per-user clip retention fallback (individual users can override in settings):
CLUTCHCLIP_CLIPS_RETENTION_HOURS=168
